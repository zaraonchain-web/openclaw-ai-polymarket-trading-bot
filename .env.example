# Data sources
POLYMARKET_REST_BASE=https://gamma-api.polymarket.com
BINANCE_REST_BASE=https://fapi.binance.com

# Real trading (default): required unless PAPER_MODE=true
PRIVATE_KEY=
CLOB_API_URL=https://clob.polymarket.com
CLOB_CHAIN_ID=137
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# Paper mode: set to true to run without CLOB credentials (no real orders)
PAPER_MODE=

# Optional: close positions after N seconds (0 = hold to market resolution)
CLOSE_AFTER_SECONDS=0

# Optional LLM scorer
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Runtime
LOOP_SECONDS=15
MAX_POSITION_USD=100
EDGE_THRESHOLD=0.03

# Optional market selection (otherwise auto-selects active BTC up/down market)
POLYMARKET_MARKET_SLUG=
POLYMARKET_MARKET_ID=
